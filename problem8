def is_prime(n):
    if n < 2:
        return False

    for i in range(2, n):
        if n % i == 0:
            return False

    return True


def goldbach_checker():
    num = int(input("Enter a number: "))

    for i in range(2, num):
        if is_prime(i) and is_prime(num - i):
            print(num, "=", i, "+", num - i)


goldbach_checker()
