def alternating_odd_sequence():
    print("--- 🌙 MOON 15: ALTERNATING ODDS ---")
    try:
        n = int(input("Enter the number of terms (N): "))
        
        if n <= 0:
            print("Please enter a positive integer.")
            return

        sequence = []
        total_sum = 0
        
        for i in range(1, n + 1):

            odd_num = 2 * i - 1
            
            if i % 2 == 0:
                current_term = -odd_num
            else:
                current_term = odd_num
                
            sequence.append(current_term)
            total_sum += current_term

        print(f"\nThe first {n} terms are:")
        print(sequence)
        print(f"The sum of the sequence is: {total_sum}")

    except ValueError:
        print("Invalid input! Please enter a whole number.")

if __name__ == "__main__":
    alternating_odd_sequence()
