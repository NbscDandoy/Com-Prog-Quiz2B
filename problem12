def alternating_fraction_series():
    n_terms = int(input("Enter number of terms: "))

    total = 0

    for n in range(1, n_terms + 1):
        if n == 1:
            term = 1
        else:
            term = n / (n + 1)
            if n % 2 == 0:
                term = -term

        total += term
        print(term)

    print("Total sum:", round(total, 4))

alternating_fraction_series()
